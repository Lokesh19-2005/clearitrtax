---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ConsultationCTA from '../components/ConsultationCTA.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { SEO } from '../data/business';
import { businessServices } from '../data/services';

const sectionIcons: Record<string, string> = {
  'setup-registration': `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>`,
  'accounting-cfo': `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>`,
  'real-estate': `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>`,
  'digital-transformation': `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
};
---

<BaseLayout
  title={SEO.business.title}
  description={SEO.business.description}
  canonicalPath="/business-advisory-services/"
>
  <Breadcrumbs items={[{ label: 'Business & Advisory Services' }]} />

  <!-- Page Header -->
  <section class="bg-gradient-to-br from-navy to-blue py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white mb-4">
        {businessServices.title}
      </h1>
      <p class="text-lg text-blue-light/90 max-w-3xl leading-relaxed">
        {businessServices.intro}
      </p>
    </div>
  </section>

  <!-- Service Sections -->
  <section class="py-12 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-12 lg:space-y-16">
        {businessServices.sections.map((section, idx) => (
          <div id={section.id} class="scroll-reveal">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-12 h-12 bg-blue-light rounded-xl flex items-center justify-center text-blue shrink-0">
                <Fragment set:html={sectionIcons[section.id] || sectionIcons['setup-registration']} />
              </div>
              <h2 class="text-xl sm:text-2xl font-bold text-navy">{section.heading}</h2>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 ml-0 lg:ml-16">
              {section.items.map((item) => (
                <div class="flex items-start gap-3 bg-bg-soft rounded-lg px-5 py-4 border border-gray-100">
                  <svg class="w-5 h-5 text-success mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  <span class="text-sm text-gray-700">{item.title}</span>
                </div>
              ))}
            </div>
            {idx < businessServices.sections.length - 1 && (
              <hr class="mt-12 border-gray-200" />
            )}
          </div>
        ))}
      </div>

      <!-- Note about legal services -->
      <div class="mt-12 p-5 bg-blue-light/50 border border-blue/10 rounded-xl scroll-reveal">
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-blue mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <p class="text-sm text-navy/80">Services described here relate to tax, accounting, and business advisory matters. For matters requiring separate legal representation, appropriate referrals can be discussed.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Related services links -->
  <section class="py-10 bg-bg-soft">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 scroll-reveal">
      <h2 class="text-xl font-bold text-navy mb-4">Explore Related Services</h2>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/income-tax-services/" class="inline-flex items-center gap-2 text-blue font-medium hover:underline">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          Income Tax Services
        </a>
        <a href="/gst-services/" class="inline-flex items-center gap-2 text-blue font-medium hover:underline">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          GST Services
        </a>
      </div>
    </div>
  </section>

  <ConsultationCTA />
  <WhatsAppButton />
</BaseLayout>
