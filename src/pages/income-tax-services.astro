---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ConsultationCTA from '../components/ConsultationCTA.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { SEO } from '../data/business';
import { incomeTaxServices } from '../data/services';

const sectionIcons: Record<string, string> = {
  'compliance-filing': `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>`,
  'advisory-planning': `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>`,
  'nri-taxation': `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>`,
  representation: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3"/></svg>`,
};
---

<BaseLayout
  title={SEO.incomeTax.title}
  description={SEO.incomeTax.description}
  canonicalPath="/income-tax-services/"
>
  <Breadcrumbs items={[{ label: 'Income Tax Services' }]} />

  <!-- Page Header -->
  <section class="bg-gradient-to-br from-navy to-blue py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white mb-4">
        {incomeTaxServices.title}
      </h1>
      <p class="text-lg text-blue-light/90 max-w-3xl leading-relaxed">
        {incomeTaxServices.intro}
      </p>
    </div>
  </section>

  <!-- Service Sections -->
  <section class="py-12 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-12 lg:space-y-16">
        {incomeTaxServices.sections.map((section, idx) => (
          <div id={section.id} class="scroll-reveal">
            <div class="flex items-center gap-4 mb-6">
              <div class="w-12 h-12 bg-blue-light rounded-xl flex items-center justify-center text-blue shrink-0">
                <Fragment set:html={sectionIcons[section.id] || sectionIcons['compliance-filing']} />
              </div>
              <h2 class="text-xl sm:text-2xl font-bold text-navy">{section.heading}</h2>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 ml-0 lg:ml-16">
              {section.items.map((item) => (
                <div class="flex items-start gap-3 bg-bg-soft rounded-lg px-5 py-4 border border-gray-100">
                  <svg class="w-5 h-5 text-success mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                  <span class="text-sm text-gray-700">{item.title}</span>
                </div>
              ))}
            </div>
            {idx < incomeTaxServices.sections.length - 1 && (
              <hr class="mt-12 border-gray-200" />
            )}
          </div>
        ))}
      </div>

      <!-- Disclaimer -->
      {incomeTaxServices.disclaimer && (
        <div class="mt-12 p-5 bg-amber-50 border border-amber-200 rounded-xl scroll-reveal">
          <div class="flex items-start gap-3">
            <svg class="w-5 h-5 text-amber-600 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <p class="text-sm text-amber-800">{incomeTaxServices.disclaimer}</p>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- Related services links -->
  <section class="py-10 bg-bg-soft">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 scroll-reveal">
      <h2 class="text-xl font-bold text-navy mb-4">Explore Related Services</h2>
      <div class="flex flex-col sm:flex-row gap-4">
        <a href="/gst-services/" class="inline-flex items-center gap-2 text-blue font-medium hover:underline">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          GST Services
        </a>
        <a href="/business-advisory-services/" class="inline-flex items-center gap-2 text-blue font-medium hover:underline">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          Business & Advisory Services
        </a>
      </div>
    </div>
  </section>

  <ConsultationCTA />
  <WhatsAppButton />
</BaseLayout>
