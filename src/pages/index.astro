---
import BaseLayout from '../layouts/BaseLayout.astro';
import ConsultationCTA from '../components/ConsultationCTA.astro';
import MapEmbed from '../components/MapEmbed.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { BUSINESS, SEO } from '../data/business';
import {
  serviceOverview,
  whyChooseUs,
  clientTypes,
  processSteps,
  featuredHighlights,
} from '../data/services';

// Icon map for service overview cards
const serviceIcons: Record<string, string> = {
  'file-text': `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>`,
  receipt: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z"/></svg>`,
  briefcase: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m8 0H8m8 0h2a2 2 0 012 2v6M8 6H6a2 2 0 00-2 2v6"/></svg>`,
};

// Icon map for why-choose-us
const whyIcons: Record<string, string> = {
  'shield-check': `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>`,
  'message-circle': `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>`,
  users: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>`,
  lock: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>`,
  globe: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>`,
  'check-circle': `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
};

// Client type icons
const clientIcons: Record<string, string> = {
  user: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>`,
  gem: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3l-8 6 3 9h10l3-9-8-6z"/><path stroke-linecap="round" stroke-linejoin="round" d="M4 9h16M8.5 18L12 9l3.5 9"/></svg>`,
  'pen-tool': `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>`,
  globe: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>`,
  store: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/></svg>`,
  handshake: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7 11l5-5m0 0l5 5m-5-5v12"/></svg>`,
  rocket: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`,
  'building-2': `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>`,
};
---

<BaseLayout
  title={SEO.home.title}
  description={SEO.home.description}
  canonicalPath="/"
>
  <!-- ===== HERO SECTION ===== -->
  <section class="relative overflow-hidden bg-gradient-to-br from-navy via-blue to-blue-accent">
    <div class="absolute inset-0 opacity-5">
      <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern id="hero-pattern" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
            <circle cx="20" cy="20" r="1.5" fill="white"/>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#hero-pattern)"/>
      </svg>
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 sm:py-20 lg:py-28">
      <div class="max-w-3xl">
        <h1 class="text-3xl sm:text-4xl lg:text-5xl xl:text-6xl font-extrabold text-white leading-tight mb-4">
          Clear ITR Tax
        </h1>
        <p class="text-lg sm:text-xl lg:text-2xl text-blue-light font-semibold mb-4">
          Your Trusted Partner for Income Tax, GST & Business Compliance
        </p>
        <p class="text-base sm:text-lg text-blue-light/90 mb-8 max-w-2xl leading-relaxed">
          Professional tax filing, GST compliance, registrations, advisory, and financial services for individuals, professionals, startups, NRIs, and businesses across India.
        </p>
        <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 mb-6">
          <a
            href="/contact/"
            class="inline-flex items-center justify-center px-7 py-4 sm:py-3.5 bg-white text-navy font-bold rounded-lg hover:bg-gray-100 active:bg-gray-200 transition-all shadow-lg hover:shadow-xl text-base w-full sm:w-auto"
          >
            File ITR Now
          </a>
          <a
            href="/gst-services/"
            class="inline-flex items-center justify-center px-7 py-4 sm:py-3.5 border-2 border-white/40 text-white font-semibold rounded-lg hover:bg-white/10 active:bg-white/20 transition-all text-base w-full sm:w-auto"
          >
            GST Services
          </a>
          <a
            href={BUSINESS.phoneHref}
            class="inline-flex items-center justify-center px-7 py-4 sm:py-3.5 bg-success text-white font-semibold rounded-lg hover:bg-success/90 active:bg-success/80 transition-all text-base w-full sm:w-auto"
          >
            Talk to Expert
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SERVICES OVERVIEW ===== -->
  <section id="services-overview" class="py-16 lg:py-24 bg-bg-soft">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 scroll-reveal">
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-navy mb-3">Our Services</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">Comprehensive tax, compliance, and business support tailored to your needs.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
        {serviceOverview.map((service) => (
          <a
            href={service.href}
            class="group bg-white rounded-2xl p-8 shadow-sm border border-gray-100 hover:shadow-lg hover:border-blue/20 transition-all duration-300 scroll-reveal"
          >
            <div class="w-14 h-14 bg-blue-light rounded-xl flex items-center justify-center text-blue mb-5 group-hover:bg-blue group-hover:text-white transition-colors duration-300">
              <Fragment set:html={serviceIcons[service.icon]} />
            </div>
            <h3 class="text-xl font-bold text-navy mb-3 group-hover:text-blue transition-colors">{service.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed mb-4">{service.description}</p>
            <span class="inline-flex items-center gap-1 text-sm font-semibold text-blue group-hover:gap-2 transition-all">
              Learn more
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== WHY CHOOSE US ===== -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 scroll-reveal">
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-navy mb-3">Why Choose Clear ITR Tax</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {whyChooseUs.map((item) => (
          <div class="text-center p-6 rounded-xl border border-gray-100 bg-bg-soft scroll-reveal">
            <div class="w-14 h-14 bg-success/10 rounded-xl flex items-center justify-center text-success mx-auto mb-4">
              <Fragment set:html={whyIcons[item.icon]} />
            </div>
            <h3 class="font-bold text-navy mb-2">{item.title}</h3>
            <p class="text-sm text-gray-600 leading-relaxed">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== MINI CTA AFTER SERVICES ===== -->
  <ConsultationCTA heading="Ready to file your ITR or GST returns?" copy="Get in touch with our experts for fast, professional filing." />

  <!-- ===== SALARY EMPLOYEE DOCUMENTS SECTION ===== -->
  <section class="py-16 lg:py-24 bg-bg-soft">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto scroll-reveal">
        <div class="bg-white rounded-2xl shadow-lg border border-gray-200 p-8 lg:p-10">
          <div class="text-center mb-8">
            <h2 class="text-2xl sm:text-3xl font-bold text-navy mb-3">Documents Required for Salaried Employees</h2>
            <p class="text-gray-600">To ensure a smooth and timely filing, please share the following details:</p>
          </div>

          <!-- Tax Info Form with file uploads -->
          <form action="https://api.web3forms.com/submit" method="POST" enctype="multipart/form-data" class="space-y-4">
            <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_ACCESS_KEY" />
            <input type="hidden" name="subject" value="New ITR Filing Request - Clear ITR Tax" />
            <input type="hidden" name="from_name" value="Clear ITR Tax Website" />
            <input type="checkbox" name="botcheck" class="hidden" style="display:none" />

            <!-- Row: Name + Number -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <div>
                <label class="block text-xs font-semibold text-navy mb-1">Name <span class="text-red-500">*</span></label>
                <input type="text" name="Name" required placeholder="John" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-accent focus:border-blue-accent" />
              </div>
              <div>
                <label class="block text-xs font-semibold text-navy mb-1">Number <span class="text-red-500">*</span></label>
                <input type="tel" name="Phone" required placeholder="1234567890" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-accent focus:border-blue-accent" />
              </div>
            </div>

            <!-- Email -->
            <div>
              <label class="block text-xs font-semibold text-navy mb-1">Email <span class="text-red-500">*</span></label>
              <input type="email" name="Email" required placeholder="john@mysite.com" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-accent focus:border-blue-accent" />
            </div>

            <!-- Row: Father Name + Pincode -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <div>
                <label class="block text-xs font-semibold text-navy mb-1">Father Name</label>
                <input type="text" name="Father Name" placeholder="Father Name" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-accent focus:border-blue-accent" />
              </div>
              <div>
                <label class="block text-xs font-semibold text-navy mb-1">Pincode</label>
                <input type="text" name="Pincode" placeholder="Pincode" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-accent focus:border-blue-accent" />
              </div>
            </div>

            <!-- Row: DOB + PAN -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <div>
                <label class="block text-xs font-semibold text-navy mb-1">Date of Birth</label>
                <input type="date" name="Date of Birth" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-accent focus:border-blue-accent" />
              </div>
              <div>
                <label class="block text-xs font-semibold text-navy mb-1">PAN Number <span class="text-red-500">*</span></label>
                <input type="text" name="PAN Number" required placeholder="PAN number" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-accent focus:border-blue-accent uppercase" />
              </div>
            </div>

            <!-- Row: Password + Bank A/C -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <div>
                <label class="block text-xs font-semibold text-navy mb-1">Password</label>
                <input type="text" name="IT Portal Password" placeholder="Password" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-accent focus:border-blue-accent" />
              </div>
              <div>
                <label class="block text-xs font-semibold text-navy mb-1">Bank A/C Number</label>
                <input type="text" name="Bank Account" placeholder="Bank a/c number" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-accent focus:border-blue-accent" />
              </div>
            </div>

            <!-- Row: IFSC + Aadhar -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <div>
                <label class="block text-xs font-semibold text-navy mb-1">IFSC Code</label>
                <input type="text" name="IFSC Code" placeholder="IFSC Code" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-accent focus:border-blue-accent uppercase" />
              </div>
              <div>
                <label class="block text-xs font-semibold text-navy mb-1">Aadhar Number</label>
                <input type="text" name="Aadhar Number" placeholder="Aadhar Number" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-accent focus:border-blue-accent" />
              </div>
            </div>

            <!-- Address -->
            <div>
              <label class="block text-xs font-semibold text-navy mb-1">Address</label>
              <textarea name="Address" rows="3" placeholder="Address" class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-accent focus:border-blue-accent resize-y"></textarea>
            </div>

            <!-- File Upload -->
            <div>
              <label class="block text-xs font-semibold text-navy mb-1">Attachments (Form-16, Investment Proofs, etc.)</label>
              <input type="file" name="attachment" multiple accept=".pdf,.jpg,.jpeg,.png,.doc,.docx" class="w-full text-sm text-gray-600 file:mr-3 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-blue-light file:text-navy hover:file:bg-blue hover:file:text-white file:transition-colors file:cursor-pointer" />
            </div>

            <!-- Row: Mutual Fund + Form-16 attachment -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <div>
                <label class="block text-xs font-semibold text-navy mb-1">Mutual Fund</label>
                <div class="flex items-center gap-4 py-1">
                  <label class="flex items-center gap-1.5 text-sm cursor-pointer"><input type="radio" name="Mutual Fund" value="Yes" class="w-4 h-4 accent-navy" /> Yes</label>
                  <label class="flex items-center gap-1.5 text-sm cursor-pointer"><input type="radio" name="Mutual Fund" value="No" checked class="w-4 h-4 accent-navy" /> No</label>
                </div>
              </div>
              <div>
                <label class="block text-xs font-semibold text-navy mb-1">Form-16 Attachment</label>
                <input type="file" name="Form 16" accept=".pdf,.jpg,.jpeg,.png" class="w-full text-sm text-gray-600 file:mr-3 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-blue-light file:text-navy hover:file:bg-blue hover:file:text-white file:transition-colors file:cursor-pointer" />
              </div>
            </div>

            <!-- Row: P&L from Broker + File -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <div>
                <label class="block text-xs font-semibold text-navy mb-1">Provide Tax P&L from Broker</label>
                <div class="flex items-center gap-4 py-1">
                  <label class="flex items-center gap-1.5 text-sm cursor-pointer"><input type="radio" name="Tax PnL from Broker" value="Yes" class="w-4 h-4 accent-navy" /> Yes</label>
                  <label class="flex items-center gap-1.5 text-sm cursor-pointer"><input type="radio" name="Tax PnL from Broker" value="No" checked class="w-4 h-4 accent-navy" /> No</label>
                </div>
              </div>
              <div>
                <label class="block text-xs font-semibold text-navy mb-1">File</label>
                <input type="file" name="Broker PnL File" accept=".pdf,.jpg,.jpeg,.png,.xlsx,.csv" class="w-full text-sm text-gray-600 file:mr-3 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-blue-light file:text-navy hover:file:bg-blue hover:file:text-white file:transition-colors file:cursor-pointer" />
              </div>
            </div>

            <!-- Send Button -->
            <button type="submit" class="w-full py-3.5 bg-[#FF1F5A] text-white font-bold rounded-lg hover:bg-[#e6174f] active:bg-[#cc1447] transition-colors shadow-lg text-base mt-2">
              Send
            </button>
          </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== GST CERTIFICATE & TRUST SECTION ===== -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 scroll-reveal">
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-navy mb-3">GST Registered & Verified Business</h2>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div class="scroll-reveal">
          <div class="rounded-2xl overflow-hidden shadow-lg border border-gray-200 max-w-md mx-auto">
            <img
              src="/images/storefront.jpg"
              alt="Clear ITR Tax GST Registration Certificate"
              class="w-full h-auto object-cover"
              loading="lazy"
              width="600"
              height="400"
            />
          </div>
        </div>
        <div class="scroll-reveal">
          <div class="space-y-4">
            <div class="flex items-center gap-3 bg-bg-soft rounded-lg px-5 py-4 border border-gray-100">
              <svg class="w-6 h-6 text-success shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
              <span class="font-semibold text-navy">GST Registered</span>
            </div>
            <div class="flex items-center gap-3 bg-bg-soft rounded-lg px-5 py-4 border border-gray-100">
              <svg class="w-6 h-6 text-success shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <span class="font-semibold text-navy">Verified Business</span>
            </div>
            <div class="flex items-center gap-3 bg-bg-soft rounded-lg px-5 py-4 border border-gray-100">
              <svg class="w-6 h-6 text-success shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
              <span class="font-semibold text-navy">Professional Consultancy</span>
            </div>
            <div class="flex items-center gap-3 bg-bg-soft rounded-lg px-5 py-4 border border-gray-100">
              <svg class="w-6 h-6 text-success shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
              <span class="font-semibold text-navy">Trusted Tax Experts</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CLIENT TYPES ===== -->
  <section class="py-16 lg:py-24 bg-bg-soft">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 scroll-reveal">
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-navy mb-3">Who We Work With</h2>
        <p class="text-gray-600">Assisting individuals, professionals, and businesses at every stage.</p>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 lg:gap-6">
        {clientTypes.map((client) => (
          <div class="bg-white rounded-xl p-5 text-center border border-gray-100 hover:border-blue/20 hover:shadow-md transition-all duration-300 scroll-reveal">
            <div class="w-12 h-12 bg-blue-light rounded-full flex items-center justify-center text-blue mx-auto mb-3">
              <Fragment set:html={clientIcons[client.icon]} />
            </div>
            <p class="text-sm font-semibold text-navy">{client.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== PROCESS ===== -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 scroll-reveal">
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-navy mb-3">
          A Straightforward Process from Consultation to Compliance
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
        {processSteps.map((step) => (
          <div class="relative scroll-reveal">
            <div class="flex items-center gap-4 mb-3">
              <span class="w-10 h-10 bg-navy text-white rounded-full flex items-center justify-center font-bold text-lg shrink-0">
                {step.step}
              </span>
              {step.step < 4 && (
                <div class="hidden lg:block flex-1 h-0.5 bg-gray-200" aria-hidden="true"></div>
              )}
            </div>
            <h3 class="font-bold text-navy mb-1.5">{step.title}</h3>
            <p class="text-sm text-gray-600 leading-relaxed">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== OFFICE GALLERY ===== -->
  <section class="py-16 lg:py-24 bg-bg-soft">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 scroll-reveal">
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-navy mb-3">Our Office & Professional Infrastructure</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 scroll-reveal">
        <div class="group relative rounded-2xl overflow-hidden shadow-md border border-gray-200 aspect-[4/3]">
          <img src="/images/storefront.jpg" alt="Clear ITR Tax Office" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" width="600" height="450" />
          <div class="absolute inset-0 bg-navy/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
            <span class="text-white font-semibold text-sm">Office Exterior</span>
          </div>
        </div>
        <div class="group relative rounded-2xl overflow-hidden shadow-md border border-gray-200 aspect-[4/3]">
          <img src="/images/visiting-card.jpg" alt="Clear ITR Tax Business Card" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" width="600" height="450" />
          <div class="absolute inset-0 bg-navy/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
            <span class="text-white font-semibold text-sm">Business Card</span>
          </div>
        </div>
        <div class="group relative rounded-2xl overflow-hidden shadow-md border border-gray-200 aspect-[4/3]">
          <img src="/images/logo.jpg" alt="Clear ITR Tax Logo" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" width="600" height="450" />
          <div class="absolute inset-0 bg-navy/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
            <span class="text-white font-semibold text-sm">Brand Logo</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== FEATURED HIGHLIGHTS ===== -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 scroll-reveal">
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-navy mb-3">Services at a Glance</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {featuredHighlights.map((highlight) => (
          <div class="flex items-center gap-3 bg-bg-soft rounded-lg px-5 py-4 border border-gray-100 scroll-reveal">
            <svg class="w-5 h-5 text-success shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
            <span class="text-sm font-medium text-navy">{highlight}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CONSULTATION CTA ===== -->
  <ConsultationCTA />

  <!-- ===== VISIT OUR OFFICE / MAP ===== -->
  <section class="py-16 lg:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 scroll-reveal">
        <h2 class="text-2xl sm:text-3xl lg:text-4xl font-bold text-navy mb-3">Visit Our Office</h2>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
        <div class="scroll-reveal">
          <div class="space-y-5">
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue mt-1 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <div>
                <p class="font-semibold text-navy">{BUSINESS.brandName}</p>
                <p class="text-sm text-gray-600">{BUSINESS.address.line1}</p>
                <p class="text-sm text-gray-600">{BUSINESS.address.line2}</p>
                <p class="text-sm text-gray-600">{BUSINESS.address.line3}</p>
                <p class="text-sm text-gray-600">{BUSINESS.address.line4}</p>
                <p class="text-sm text-gray-600">{BUSINESS.address.locality}, {BUSINESS.address.city}, {BUSINESS.address.state} {BUSINESS.address.pin}</p>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-blue shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              <a href={BUSINESS.phoneHref} class="text-gray-600 hover:text-navy transition-colors">{BUSINESS.phone}</a>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-blue shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              <a href={BUSINESS.emailHref} class="text-gray-600 hover:text-navy transition-colors break-all">{BUSINESS.email}</a>
            </div>
          </div>
        </div>
        <div class="scroll-reveal">
          <MapEmbed />
        </div>
      </div>
    </div>
  </section>

  <WhatsAppButton />
</BaseLayout>
