---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ConsultationCTA from '../components/ConsultationCTA.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { BUSINESS, SEO } from '../data/business';
---

<BaseLayout
  title={SEO.about.title}
  description={SEO.about.description}
  canonicalPath="/about/"
>
  <Breadcrumbs items={[{ label: 'About Us' }]} />

  <!-- Page Header -->
  <section class="bg-gradient-to-br from-navy to-blue py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white mb-4">
        Professional Tax and Business Support You Can Understand
      </h1>
    </div>
  </section>

  <!-- About Content -->
  <section class="py-12 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-start">
        <!-- Text -->
        <div class="scroll-reveal">
          <h2 class="text-2xl font-bold text-navy mb-6">About Clear ITR Tax</h2>
          <div class="prose prose-slate max-w-none space-y-4 text-gray-600 leading-relaxed">
            <p>
              <strong class="text-navy">Clear ITR Tax</strong> is the customer-facing tax and compliance brand of
              <strong class="text-navy">Nettyam Associates</strong>. The firm assists individuals, professionals,
              proprietors, partnerships, LLPs, startups, and businesses with Income Tax, GST, accounting,
              registration, and advisory requirements.
            </p>
            <p>
              Based in Chikkajala, Bengaluru, we work with clients across Karnataka and India — providing
              practical, compliance-focused support that helps you stay on top of your tax and regulatory
              obligations without unnecessary complexity.
            </p>
            <p>
              Our approach centres on understanding each client's specific situation, delivering accurate
              work within timelines, and maintaining clear communication throughout the engagement.
            </p>
          </div>

          <!-- Values -->
          <div class="mt-10">
            <h3 class="text-xl font-bold text-navy mb-6">Our Values</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {[
                { icon: '✓', title: 'Accuracy', desc: 'Every filing and computation is reviewed for correctness.' },
                { icon: '⏱', title: 'Timeliness', desc: 'We respect deadlines — yours and the department\'s.' },
                { icon: '🔒', title: 'Confidentiality', desc: 'Your financial information is handled with strict confidence.' },
                { icon: '💬', title: 'Clear Communication', desc: 'We explain things in plain language, not jargon.' },
                { icon: '🧭', title: 'Practical Guidance', desc: 'Advice grounded in applicable law and real-world context.' },
                { icon: '🤝', title: 'Long-Term Relationships', desc: 'We aim to be your ongoing compliance partner.' },
              ].map((value) => (
                <div class="flex items-start gap-3 bg-bg-soft rounded-lg px-5 py-4 border border-gray-100">
                  <span class="text-lg shrink-0" aria-hidden="true">{value.icon}</span>
                  <div>
                    <p class="font-semibold text-navy text-sm">{value.title}</p>
                    <p class="text-xs text-gray-600 mt-0.5">{value.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- Storefront Image -->
        <div class="scroll-reveal">
          <div class="rounded-2xl overflow-hidden shadow-lg border border-gray-200">
            <img
              src="/images/storefront.jpg"
              alt="Clear ITR Tax office entrance at Sri Venkateswara Nilayam, Chikkajala, Bengaluru — a professional tax consulting office with clear signage"
              class="w-full h-auto object-cover"
              loading="lazy"
              width="1024"
              height="768"
            />
          </div>
          <p class="text-xs text-gray-500 mt-3 text-center">
            Our office at Sri Venkateswara Nilayam, Chikkajala, Bengaluru
          </p>

          <!-- Brand relationship card -->
          <div class="mt-8 bg-navy rounded-xl p-6 text-white">
            <p class="font-bold text-lg mb-2">{BUSINESS.brandName}</p>
            <p class="text-sm text-blue-light/80 mb-4">{BUSINESS.brandRelation}</p>
            <div class="space-y-2">
              <a href={BUSINESS.phoneHref} class="flex items-center gap-2 text-sm text-blue-light/90 hover:text-white transition-colors">
                <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                {BUSINESS.phone}
              </a>
              <a href={BUSINESS.emailHref} class="flex items-center gap-2 text-sm text-blue-light/90 hover:text-white transition-colors">
                <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                {BUSINESS.email}
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services overview -->
  <section class="py-12 bg-bg-soft">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 scroll-reveal">
      <h2 class="text-2xl font-bold text-navy mb-6 text-center">What We Do</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <a href="/income-tax-services/" class="bg-white rounded-xl p-6 border border-gray-100 hover:shadow-md hover:border-blue/20 transition-all text-center">
          <svg class="w-8 h-8 text-blue mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          <h3 class="font-bold text-navy mb-1">Income Tax Services</h3>
          <p class="text-xs text-gray-600">Filing, planning, NRI taxation, and representation</p>
        </a>
        <a href="/gst-services/" class="bg-white rounded-xl p-6 border border-gray-100 hover:shadow-md hover:border-blue/20 transition-all text-center">
          <svg class="w-8 h-8 text-blue mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 14l6-6m-5.5.5h.01m4.99 5h.01M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16l3.5-2 3.5 2 3.5-2 3.5 2z"/></svg>
          <h3 class="font-bold text-navy mb-1">GST Services</h3>
          <p class="text-xs text-gray-600">Registration, returns, audits, and refunds</p>
        </a>
        <a href="/business-advisory-services/" class="bg-white rounded-xl p-6 border border-gray-100 hover:shadow-md hover:border-blue/20 transition-all text-center">
          <svg class="w-8 h-8 text-blue mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m8 0H8m8 0h2a2 2 0 012 2v6M8 6H6a2 2 0 00-2 2v6"/></svg>
          <h3 class="font-bold text-navy mb-1">Business & Advisory</h3>
          <p class="text-xs text-gray-600">Registrations, accounting, and digital transformation</p>
        </a>
      </div>
    </div>
  </section>

  <ConsultationCTA
    heading="Ready to simplify your tax and compliance needs?"
    copy="Get in touch with Clear ITR Tax for a consultation."
  />
  <WhatsAppButton />
</BaseLayout>
