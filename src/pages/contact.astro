---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ContactForm from '../components/ContactForm.astro';
import MapEmbed from '../components/MapEmbed.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { BUSINESS, SEO } from '../data/business';
---

<BaseLayout
  title={SEO.contact.title}
  description={SEO.contact.description}
  canonicalPath="/contact/"
>
  <Breadcrumbs items={[{ label: 'Contact' }]} />

  <!-- Page Header -->
  <section class="bg-gradient-to-br from-navy to-blue py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white mb-4">
        Contact Clear ITR Tax
      </h1>
      <p class="text-lg text-blue-light/90 max-w-3xl">
        Reach out for a consultation on Income Tax, GST, accounting, or business advisory matters.
      </p>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="py-12 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16">
        <!-- Contact Info + Map -->
        <div class="space-y-8">
          <!-- Brand info -->
          <div class="scroll-reveal">
            <h2 class="text-2xl font-bold text-navy mb-1">{BUSINESS.brandName}</h2>
            <p class="text-sm text-gray-500 mb-6">{BUSINESS.brandRelation}</p>

            <!-- Contact details -->
            <div class="space-y-5">
              <!-- Phone -->
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-blue-light rounded-lg flex items-center justify-center text-blue shrink-0">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                </div>
                <div>
                  <p class="font-semibold text-navy text-sm">Phone</p>
                  <a href={BUSINESS.phoneHref} class="text-gray-600 hover:text-blue transition-colors">{BUSINESS.phone}</a>
                </div>
              </div>

              <!-- Email -->
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-blue-light rounded-lg flex items-center justify-center text-blue shrink-0">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                <div>
                  <p class="font-semibold text-navy text-sm">Email</p>
                  <a href={BUSINESS.emailHref} class="text-gray-600 hover:text-blue transition-colors break-all">{BUSINESS.email}</a>
                </div>
              </div>

              <!-- Address -->
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-blue-light rounded-lg flex items-center justify-center text-blue shrink-0">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <div>
                  <p class="font-semibold text-navy text-sm">Office Address</p>
                  <address class="text-sm text-gray-600 not-italic leading-relaxed">
                    {BUSINESS.address.line1}<br />
                    {BUSINESS.address.line2}<br />
                    {BUSINESS.address.line3}<br />
                    {BUSINESS.address.line4}<br />
                    {BUSINESS.address.locality}, {BUSINESS.address.city},<br />
                    {BUSINESS.address.state} {BUSINESS.address.pin}, {BUSINESS.address.country}
                  </address>
                </div>
              </div>

              <!-- Hours -->
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-blue-light rounded-lg flex items-center justify-center text-blue shrink-0">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <div>
                  <p class="font-semibold text-navy text-sm">Availability</p>
                  <p class="text-sm text-gray-600">{BUSINESS.hours}</p>
                </div>
              </div>
            </div>

            <!-- Action buttons -->
            <div class="flex flex-col sm:flex-row gap-3 mt-8">
              <a
                href={BUSINESS.phoneHref}
                class="inline-flex items-center justify-center gap-2 px-5 py-3 bg-navy text-white font-semibold rounded-lg hover:bg-blue transition-colors shadow-sm"
                id="contact-call-btn"
              >
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                Call Now
              </a>
              <a
                href={BUSINESS.emailHref}
                class="inline-flex items-center justify-center gap-2 px-5 py-3 border-2 border-navy text-navy font-semibold rounded-lg hover:bg-navy hover:text-white transition-colors"
                id="contact-email-btn"
              >
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                Send Email
              </a>
              <a
                href={BUSINESS.googleMapsUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-2 px-5 py-3 border-2 border-gray-300 text-gray-700 font-semibold rounded-lg hover:border-navy hover:text-navy transition-colors"
                id="contact-directions-btn"
              >
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                Get Directions
              </a>
            </div>

            <!-- Digital Business Card -->
            <div class="mt-8 p-6 bg-bg-soft border border-gray-100 rounded-xl scroll-reveal">
              <h3 class="text-lg font-bold text-navy mb-2 font-sans">Digital Business Card</h3>
              <p class="text-xs text-gray-600 mb-4">View or download our official visiting card to keep our contact details handy.</p>
              <div class="relative group overflow-hidden rounded-xl border border-gray-200 shadow-sm max-w-md">
                <img 
                  src="/images/visiting-card.jpg" 
                  alt="Nettyam Associates GST & Income Tax Consultant Visiting Card" 
                  class="w-full h-auto object-cover"
                  loading="lazy"
                  width="1024"
                  height="576"
                />
                <div class="absolute inset-0 bg-navy/80 opacity-0 group-hover:opacity-100 flex items-center justify-center transition-all duration-200">
                  <a 
                    href="/images/visiting-card.jpg" 
                    download="Nettyam-Associates-Visiting-Card.jpg" 
                    class="px-5 py-2.5 bg-white text-navy text-sm font-semibold rounded-lg hover:bg-blue hover:text-white transition-colors shadow"
                  >
                    Download Card
                  </a>
                </div>
              </div>
            </div>
          </div>

          <!-- Map -->
          <div class="scroll-reveal">
            <MapEmbed />
          </div>
        </div>

        <!-- Enquiry Form -->
        <div class="scroll-reveal">
          <ContactForm />
        </div>
      </div>
    </div>
  </section>

  <WhatsAppButton />
</BaseLayout>
