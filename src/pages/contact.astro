---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import ContactForm from '../components/ContactForm.astro';
import MapEmbed from '../components/MapEmbed.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
import { BUSINESS, SEO } from '../data/business';
---

<BaseLayout
  title={SEO.contact.title}
  description={SEO.contact.description}
  canonicalPath="/contact/"
>
  <Breadcrumbs items={[{ label: 'Contact' }]} />

  <!-- Page Header -->
  <section class="bg-gradient-to-br from-navy to-blue py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold text-white mb-4">
        Contact Clear ITR Tax
      </h1>
      <p class="text-lg text-blue-light/90 max-w-3xl">
        Reach out for a consultation on Income Tax, GST, accounting, or business advisory matters.
      </p>
    </div>
  </section>

  <!-- Contact Content -->
  <section class="py-12 lg:py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16">
        <!-- Contact Info + Map -->
        <div class="space-y-8">
          <div class="scroll-reveal">
            <h2 class="text-2xl font-bold text-navy mb-1">{BUSINESS.brandName}</h2>
            <p class="text-sm text-gray-500 mb-6">Operated by Nettyam Associates</p>

            <!-- Contact details -->
            <div class="space-y-5">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-blue-light rounded-lg flex items-center justify-center text-blue shrink-0">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                </div>
                <div>
                  <p class="font-semibold text-navy text-sm">Phone</p>
                  <a href={BUSINESS.phoneHref} class="text-gray-600 hover:text-blue transition-colors">{BUSINESS.phone}</a>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-blue-light rounded-lg flex items-center justify-center text-blue shrink-0">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                </div>
                <div>
                  <p class="font-semibold text-navy text-sm">Email</p>
                  <a href={BUSINESS.emailHref} class="text-gray-600 hover:text-blue transition-colors break-all">{BUSINESS.email}</a>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-blue-light rounded-lg flex items-center justify-center text-blue shrink-0">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
                </div>
                <div>
                  <p class="font-semibold text-navy text-sm">Website</p>
                  <a href="https://clearitrtax.com" class="text-gray-600 hover:text-blue transition-colors">https://clearitrtax.com</a>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-10 h-10 bg-blue-light rounded-lg flex items-center justify-center text-blue shrink-0">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                </div>
                <div>
                  <p class="font-semibold text-navy text-sm">Office Address</p>
                  <address class="text-sm text-gray-600 not-italic leading-relaxed">
                    {BUSINESS.address.line1}<br />
                    {BUSINESS.address.line2}<br />
                    {BUSINESS.address.line3}<br />
                    {BUSINESS.address.line4}<br />
                    {BUSINESS.address.locality}, {BUSINESS.address.city},<br />
                    {BUSINESS.address.state} {BUSINESS.address.pin}, {BUSINESS.address.country}
                  </address>
                </div>
              </div>
            </div>

            <!-- Action buttons -->
            <div class="flex flex-col sm:flex-row gap-3 mt-8">
              <a href={BUSINESS.phoneHref} class="inline-flex items-center justify-center gap-2 px-5 py-3 bg-navy text-white font-semibold rounded-lg hover:bg-blue transition-colors shadow-sm">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                Call Now
              </a>
              <a href={BUSINESS.emailHref} class="inline-flex items-center justify-center gap-2 px-5 py-3 border-2 border-navy text-navy font-semibold rounded-lg hover:bg-navy hover:text-white transition-colors">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                Send Email
              </a>
              <a href={BUSINESS.whatsappUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 px-5 py-3 bg-[#25D366] text-white font-semibold rounded-lg hover:bg-[#128C7E] transition-colors">
                <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                WhatsApp
              </a>
            </div>
          </div>

          <!-- Map -->
          <div class="scroll-reveal">
            <MapEmbed />
          </div>
        </div>

        <!-- Enquiry Form -->
        <div class="scroll-reveal">
          <ContactForm />
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SALARY EMPLOYEE DOCUMENTS SECTION ===== -->
  <section class="py-12 lg:py-20 bg-bg-soft">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto scroll-reveal">
        <div class="bg-white rounded-2xl shadow-lg border border-gray-200 p-8 lg:p-10">
          <div class="text-center mb-8">
            <h2 class="text-2xl sm:text-3xl font-bold text-navy mb-3">Documents Required for Salaried Employees</h2>
            <p class="text-gray-600">To ensure a smooth and timely Income Tax Return filing, please share the following details:</p>
          </div>
          <div class="space-y-4 mb-8">
            <div class="flex items-center gap-3 bg-bg-soft rounded-lg px-5 py-4 border border-gray-100">
              <svg class="w-5 h-5 text-success shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span class="text-sm font-medium text-navy">Form 16 (Part A & Part B)</span>
            </div>
            <div class="flex items-center gap-3 bg-bg-soft rounded-lg px-5 py-4 border border-gray-100">
              <svg class="w-5 h-5 text-success shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span class="text-sm font-medium text-navy">PAN Number</span>
            </div>
            <div class="flex items-center gap-3 bg-bg-soft rounded-lg px-5 py-4 border border-gray-100">
              <svg class="w-5 h-5 text-success shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span class="text-sm font-medium text-navy">Income Tax Portal Password</span>
            </div>
            <div class="flex items-center gap-3 bg-bg-soft rounded-lg px-5 py-4 border border-gray-100">
              <svg class="w-5 h-5 text-success shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              <span class="text-sm font-medium text-navy">Investment Proofs (if not reflected in Form 16)</span>
            </div>
          </div>
          <div class="text-center">
            <p class="text-sm text-gray-600 mb-4">Submit documents to: <a href={BUSINESS.emailHref} class="text-blue font-semibold hover:underline">{BUSINESS.email}</a></p>
            <a href={BUSINESS.emailHref} class="inline-flex items-center justify-center px-7 py-3 bg-navy text-white font-semibold rounded-lg hover:bg-blue transition-colors shadow-sm">
              Email Documents
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== OFFICE GALLERY ===== -->
  <section class="py-12 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12 scroll-reveal">
        <h2 class="text-2xl sm:text-3xl font-bold text-navy mb-3">Our Office & Professional Infrastructure</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 scroll-reveal">
        <div class="group relative rounded-2xl overflow-hidden shadow-md border border-gray-200 aspect-[4/3]">
          <img src="/images/storefront.jpg" alt="Clear ITR Tax Office" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" width="600" height="450" />
          <div class="absolute inset-0 bg-navy/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
            <span class="text-white font-semibold text-sm">Office Exterior</span>
          </div>
        </div>
        <div class="group relative rounded-2xl overflow-hidden shadow-md border border-gray-200 aspect-[4/3]">
          <img src="/images/visiting-card.jpg" alt="Clear ITR Tax Business Card" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" width="600" height="450" />
          <div class="absolute inset-0 bg-navy/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
            <span class="text-white font-semibold text-sm">Business Card</span>
          </div>
        </div>
        <div class="group relative rounded-2xl overflow-hidden shadow-md border border-gray-200 aspect-[4/3]">
          <img src="/images/logo.jpg" alt="Clear ITR Tax Logo" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" width="600" height="450" />
          <div class="absolute inset-0 bg-navy/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
            <span class="text-white font-semibold text-sm">Brand Logo</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <WhatsAppButton />
</BaseLayout>
