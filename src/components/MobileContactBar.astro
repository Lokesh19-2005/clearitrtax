---
import { BUSINESS } from '../data/business';
---

<!-- Mobile bottom contact bar — visible only on small screens -->
<div class="fixed bottom-0 left-0 right-0 z-40 lg:hidden bg-navy border-t border-blue/30 shadow-[0_-4px_12px_rgba(0,0,0,0.15)]">
  <div class="grid grid-cols-3 divide-x divide-blue/30">
    <a
      href={BUSINESS.phoneHref}
      class="flex flex-col items-center justify-center py-2.5 text-white hover:bg-blue/20 transition-colors"
      aria-label="Call Clear ITR Tax"
    >
      <svg class="w-5 h-5 mb-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
      <span class="text-[11px] font-medium">Call Now</span>
    </a>
    <a
      href={BUSINESS.emailHref}
      class="flex flex-col items-center justify-center py-2.5 text-white hover:bg-blue/20 transition-colors"
      aria-label="Email Clear ITR Tax"
    >
      <svg class="w-5 h-5 mb-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
      <span class="text-[11px] font-medium">Email</span>
    </a>
    <a
      href={BUSINESS.googleMapsUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="flex flex-col items-center justify-center py-2.5 text-white hover:bg-blue/20 transition-colors"
      aria-label="Get directions to Clear ITR Tax office"
    >
      <svg class="w-5 h-5 mb-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
      <span class="text-[11px] font-medium">Directions</span>
    </a>
  </div>
</div>

<!-- Spacer to prevent content from being hidden behind the fixed bar on mobile -->
<div class="h-16 lg:hidden" aria-hidden="true"></div>
