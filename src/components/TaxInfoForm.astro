---
import { BUSINESS } from '../data/business';
---

<div class="bg-navy rounded-2xl shadow-xl p-6 sm:p-8" id="contact-form-section">
  <h3 class="text-2xl sm:text-3xl font-bold text-white mb-6 text-center">Contact Us</h3>

  <form id="tax-info-form" class="space-y-4" enctype="multipart/form-data">
    <!-- Row: Name + Number -->
    <div class="grid grid-cols-2 gap-3">
      <div>
        <label class="block text-xs font-bold text-white mb-1">Name</label>
        <input type="text" name="name" required placeholder="John" class="w-full px-3 py-2.5 bg-white border-0 rounded text-sm text-navy placeholder:text-gray-400" />
      </div>
      <div>
        <label class="block text-xs font-bold text-white mb-1">Number</label>
        <input type="tel" name="phone" required placeholder="1234567890" class="w-full px-3 py-2.5 bg-white border-0 rounded text-sm text-navy placeholder:text-gray-400" />
      </div>
    </div>

    <!-- Email -->
    <div>
      <label class="block text-xs font-bold text-white mb-1">Email</label>
      <input type="email" name="email" required placeholder="john@mysite.com" class="w-full px-3 py-2.5 bg-white border-0 rounded text-sm text-navy placeholder:text-gray-400" />
    </div>

    <!-- Row: Father Name + Pincode -->
    <div class="grid grid-cols-2 gap-3">
      <div>
        <label class="block text-xs font-bold text-white mb-1">Father Name</label>
        <input type="text" name="fatherName" placeholder="Father Name" class="w-full px-3 py-2.5 bg-white border-0 rounded text-sm text-navy placeholder:text-gray-400" />
      </div>
      <div>
        <label class="block text-xs font-bold text-white mb-1">Pincode</label>
        <input type="text" name="pincode" placeholder="Pincode" class="w-full px-3 py-2.5 bg-white border-0 rounded text-sm text-navy placeholder:text-gray-400" />
      </div>
    </div>

    <!-- Row: DOB + PAN -->
    <div class="grid grid-cols-2 gap-3">
      <div>
        <label class="block text-xs font-bold text-white mb-1">Date of birth</label>
        <input type="date" name="dob" class="w-full px-3 py-2.5 bg-white border-0 rounded text-sm text-navy" />
      </div>
      <div>
        <label class="block text-xs font-bold text-white mb-1">Pan number</label>
        <input type="text" name="pan" placeholder="Pan number" class="w-full px-3 py-2.5 bg-white border-0 rounded text-sm text-navy placeholder:text-gray-400 uppercase" />
      </div>
    </div>

    <!-- Row: Password + Bank a/c -->
    <div class="grid grid-cols-2 gap-3">
      <div>
        <label class="block text-xs font-bold text-white mb-1">Password</label>
        <input type="text" name="password" placeholder="Password" class="w-full px-3 py-2.5 bg-white border-0 rounded text-sm text-navy placeholder:text-gray-400" />
      </div>
      <div>
        <label class="block text-xs font-bold text-white mb-1">Bank a/c number</label>
        <input type="text" name="bankAccount" placeholder="Bank a/c number" class="w-full px-3 py-2.5 bg-white border-0 rounded text-sm text-navy placeholder:text-gray-400" />
      </div>
    </div>

    <!-- Row: IFSC + Aadhar -->
    <div class="grid grid-cols-2 gap-3">
      <div>
        <label class="block text-xs font-bold text-white mb-1">IFSC Code</label>
        <input type="text" name="ifsc" placeholder="IFSC Code" class="w-full px-3 py-2.5 bg-white border-0 rounded text-sm text-navy placeholder:text-gray-400 uppercase" />
      </div>
      <div>
        <label class="block text-xs font-bold text-white mb-1">Aadhar Number</label>
        <input type="text" name="aadhar" placeholder="Aadhar Number" class="w-full px-3 py-2.5 bg-white border-0 rounded text-sm text-navy placeholder:text-gray-400" />
      </div>
    </div>

    <!-- Address -->
    <div>
      <label class="block text-xs font-bold text-white mb-1">Address</label>
      <textarea name="address" rows="3" placeholder="Address" class="w-full px-3 py-2.5 bg-white border-0 rounded text-sm text-navy placeholder:text-gray-400 resize-y"></textarea>
    </div>

    <!-- Form-16 Yes/No + File -->
    <div>
      <label class="block text-xs font-bold text-white mb-1">Form-16</label>
      <div class="flex items-center gap-4">
        <div class="flex items-center gap-3">
          <label class="flex items-center gap-1.5 text-sm text-white cursor-pointer"><input type="radio" name="form16" value="yes" class="w-4 h-4" /> yes</label>
          <label class="flex items-center gap-1.5 text-sm text-white cursor-pointer"><input type="radio" name="form16" value="no" checked class="w-4 h-4" /> no</label>
        </div>
        <input type="file" name="form16File" accept=".pdf,.jpg,.jpeg,.png" class="text-xs text-white file:mr-2 file:py-1 file:px-3 file:rounded file:border file:border-white/40 file:text-xs file:bg-transparent file:text-white file:cursor-pointer" />
      </div>
    </div>

    <!-- Mutual Fund Yes/No + Form 16 Upload -->
    <div class="grid grid-cols-2 gap-3">
      <div>
        <label class="block text-xs font-bold text-white mb-1">Mutal fund</label>
        <div class="flex items-center gap-3">
          <label class="flex items-center gap-1.5 text-sm text-white cursor-pointer"><input type="radio" name="mutualFund" value="yes" class="w-4 h-4" /> yes</label>
          <label class="flex items-center gap-1.5 text-sm text-white cursor-pointer"><input type="radio" name="mutualFund" value="no" checked class="w-4 h-4" /> no</label>
        </div>
      </div>
      <div>
        <label class="block text-xs font-bold text-white mb-1">Form 16 Upload</label>
        <input type="file" name="form16Upload" accept=".pdf,.jpg,.jpeg,.png" class="text-xs text-white file:mr-2 file:py-1 file:px-3 file:rounded file:border file:border-white/40 file:text-xs file:bg-transparent file:text-white file:cursor-pointer" />
      </div>
    </div>

    <!-- Tax P&L + File -->
    <div class="grid grid-cols-2 gap-3">
      <div>
        <label class="block text-xs font-bold text-white mb-1">Tax P&L</label>
        <div class="flex items-center gap-3">
          <label class="flex items-center gap-1.5 text-sm text-white cursor-pointer"><input type="radio" name="taxPnl" value="yes" class="w-4 h-4" /> yes</label>
          <label class="flex items-center gap-1.5 text-sm text-white cursor-pointer"><input type="radio" name="taxPnl" value="no" checked class="w-4 h-4" /> no</label>
        </div>
      </div>
      <div>
        <label class="block text-xs font-bold text-white mb-1">&nbsp;</label>
        <input type="file" name="taxPnlFile" accept=".pdf,.jpg,.jpeg,.png,.xlsx,.csv" class="text-xs text-white file:mr-2 file:py-1 file:px-3 file:rounded file:border file:border-white/40 file:text-xs file:bg-transparent file:text-white file:cursor-pointer" />
      </div>
    </div>

    <!-- Broker Dropdown -->
    <div>
      <select name="broker" class="w-full px-3 py-2.5 bg-white border-0 rounded text-sm text-navy">
        <option value="Angel One">Angel One</option>
        <option value="Zerodha">Zerodha</option>
        <option value="Groww">Groww</option>
        <option value="Upstox">Upstox</option>
        <option value="ICICI Direct">ICICI Direct</option>
        <option value="HDFC Securities">HDFC Securities</option>
        <option value="Other">Other</option>
        <option value="None">None</option>
      </select>
    </div>

    <!-- Send Button -->
    <button
      type="submit"
      class="w-full py-3.5 bg-[#FF1F5A] text-white font-bold rounded-lg hover:bg-[#e6174f] active:bg-[#cc1447] transition-colors shadow-lg text-base"
      id="tax-form-submit"
    >
      Send
    </button>
  </form>

  <!-- Success message (hidden by default) -->
  <div id="form-success" class="hidden text-center py-8">
    <svg class="w-16 h-16 text-green-400 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    <p class="text-white text-lg font-semibold">Form Submitted Successfully!</p>
    <p class="text-blue-light/80 text-sm mt-2">We'll get back to you shortly.</p>
  </div>
</div>

<script>
  const form = document.getElementById('tax-info-form');
  const successMsg = document.getElementById('form-success');
  const submitBtn = document.getElementById('tax-form-submit');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    submitBtn.textContent = 'Sending...';
    submitBtn.disabled = true;

    const formData = new FormData(form);

    try {
      const response = await fetch('/api/submit', {
        method: 'POST',
        body: formData,
      });

      if (response.ok) {
        form.classList.add('hidden');
        successMsg?.classList.remove('hidden');
      } else {
        alert('Something went wrong. Please try again or call us directly.');
        submitBtn.textContent = 'Send';
        submitBtn.disabled = false;
      }
    } catch (error) {
      alert('Network error. Please try again or call us directly.');
      submitBtn.textContent = 'Send';
      submitBtn.disabled = false;
    }
  });
</script>
