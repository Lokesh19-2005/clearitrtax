---
import { BUSINESS } from '../data/business';
import { navLinks } from '../data/navigation';
---

<footer class="bg-gray-900 text-gray-300 mt-auto">
  <!-- Main footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-12">
      <!-- Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-block mb-4" aria-label="Clear ITR Tax — Home">
          <img src="/images/logo.png" alt="Clear ITR Tax logo" class="h-20 w-auto brightness-0 invert" width="80" height="80" />
        </a>
        <p class="text-sm text-gray-400 leading-relaxed">
          {BUSINESS.brandRelation}
        </p>
        <p class="text-sm text-gray-400 mt-3">
          {BUSINESS.tagline}
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Quick Links</h3>
        <ul class="space-y-2.5">
          {navLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm text-gray-400 hover:text-white transition-colors duration-200">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Services</h3>
        <ul class="space-y-2.5">
          <li><a href="/income-tax-services/" class="text-sm text-gray-400 hover:text-white transition-colors duration-200">Income Tax Filing</a></li>
          <li><a href="/income-tax-services/#advisory-planning" class="text-sm text-gray-400 hover:text-white transition-colors duration-200">Tax Planning</a></li>
          <li><a href="/gst-services/" class="text-sm text-gray-400 hover:text-white transition-colors duration-200">GST Registration & Returns</a></li>
          <li><a href="/business-advisory-services/" class="text-sm text-gray-400 hover:text-white transition-colors duration-200">Business Registration</a></li>
          <li><a href="/business-advisory-services/#accounting-cfo" class="text-sm text-gray-400 hover:text-white transition-colors duration-200">Accounting & Bookkeeping</a></li>
          <li><a href="/income-tax-services/#nri-taxation" class="text-sm text-gray-400 hover:text-white transition-colors duration-200">NRI Taxation</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Contact Us</h3>
        <ul class="space-y-3">
          <li>
            <a href={BUSINESS.phoneHref} class="flex items-start gap-2.5 text-sm text-gray-400 hover:text-white transition-colors">
              <svg class="w-4 h-4 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              {BUSINESS.phone}
            </a>
          </li>
          <li>
            <a href={BUSINESS.emailHref} class="flex items-start gap-2.5 text-sm text-gray-400 hover:text-white transition-colors">
              <svg class="w-4 h-4 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              {BUSINESS.email}
            </a>
          </li>
          <li>
            <a href={BUSINESS.googleMapsUrl} target="_blank" rel="noopener noreferrer" class="flex items-start gap-2.5 text-sm text-gray-400 hover:text-white transition-colors">
              <svg class="w-4 h-4 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <span>{BUSINESS.address.locality}, {BUSINESS.address.city}, {BUSINESS.address.state} {BUSINESS.address.pin}</span>
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="text-xs text-gray-500 text-center md:text-left">
          &copy; {new Date().getFullYear()} {BUSINESS.legalName}. All rights reserved.
        </p>
        <p class="text-xs text-gray-500 text-center md:text-right max-w-2xl">
          The information on this website is for general guidance and does not constitute legal, investment, or tax advice. Services are subject to document review, applicable laws, and engagement terms.
        </p>
      </div>
    </div>
  </div>
</footer>
