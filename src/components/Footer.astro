---
import { BUSINESS } from '../data/business';
---

<footer class="bg-gray-900 text-gray-300 mt-auto">
  <!-- Main footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10 lg:gap-12">
      <!-- Brand -->
      <div>
        <a href="/" class="inline-block mb-4" aria-label="Clear ITR Tax — Home">
          <img src="/images/logo.png" alt="Clear ITR Tax logo" class="h-20 w-auto brightness-0 invert" width="80" height="80" />
        </a>
        <p class="text-lg font-bold text-white mb-2">Clear ITR Tax</p>
        <p class="text-sm text-gray-400 leading-relaxed">
          Professional Income Tax, GST and Business Compliance Services.
        </p>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Services</h3>
        <ul class="space-y-2.5">
          <li><a href="/income-tax-services/" class="text-sm text-gray-400 hover:text-white transition-colors duration-200">Income Tax</a></li>
          <li><a href="/gst-services/" class="text-sm text-gray-400 hover:text-white transition-colors duration-200">GST</a></li>
          <li><a href="/business-advisory-services/" class="text-sm text-gray-400 hover:text-white transition-colors duration-200">Business Registration</a></li>
          <li><a href="/business-advisory-services/#setup-registration" class="text-sm text-gray-400 hover:text-white transition-colors duration-200">MSME Registration</a></li>
          <li><a href="/business-advisory-services/#accounting-cfo" class="text-sm text-gray-400 hover:text-white transition-colors duration-200">Virtual CFO</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Contact</h3>
        <ul class="space-y-3">
          <li>
            <a href={BUSINESS.emailHref} class="flex items-start gap-2.5 text-sm text-gray-400 hover:text-white transition-colors">
              <svg class="w-4 h-4 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              {BUSINESS.email}
            </a>
          </li>
          <li>
            <a href={BUSINESS.phoneHref} class="flex items-start gap-2.5 text-sm text-gray-400 hover:text-white transition-colors">
              <svg class="w-4 h-4 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              {BUSINESS.phone}
            </a>
          </li>
          <li>
            <a href="https://clearitrtax.com" class="flex items-start gap-2.5 text-sm text-gray-400 hover:text-white transition-colors">
              <svg class="w-4 h-4 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
              https://clearitrtax.com
            </a>
          </li>
          <li>
            <a href={BUSINESS.googleMapsUrl} target="_blank" rel="noopener noreferrer" class="flex items-start gap-2.5 text-sm text-gray-400 hover:text-white transition-colors">
              <svg class="w-4 h-4 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <span>{BUSINESS.address.locality}, {BUSINESS.address.city}, {BUSINESS.address.state} {BUSINESS.address.pin}</span>
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-gray-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="flex flex-col items-center gap-3">
        <p class="text-xs text-gray-500 text-center">
          &copy; 2026 Clear ITR Tax. All Rights Reserved.
        </p>
        <p class="text-xs text-gray-500 text-center">
          Clear ITR Tax is a service brand operated by Nettyam Associates.
        </p>
      </div>
    </div>
  </div>
</footer>
