---
const mapQuery = encodeURIComponent('Nettyam Associates, Sri Venkateswara Nilayam, Chikkajala, Bengaluru, Karnataka 562157');
const embedUrl = `https://www.google.com/maps?q=${mapQuery}&output=embed`;
---

<div class="w-full rounded-xl overflow-hidden shadow-md border border-gray-200">
  <iframe
    title="Clear ITR Tax office location on Google Maps"
    src={embedUrl}
    width="100%"
    height="350"
    style="border:0;"
    allowfullscreen
    loading="lazy"
    referrerpolicy="no-referrer-when-downgrade"
    class="w-full"
  ></iframe>
</div>
