---
/**
 * WhatsApp floating button.
 * Enabled/Disabled via BUSINESS.whatsappEnabled in src/data/business.ts
 */
import { BUSINESS } from '../data/business';
---

{BUSINESS.whatsappEnabled && (
  <div class="fixed bottom-20 right-4 lg:bottom-6 lg:right-6 z-50 flex items-center group whatsapp-group" id="whatsapp-container">
    {/* Tooltip */}
    <div
      id="whatsapp-tooltip"
      class="absolute right-16 top-1/2 -translate-y-1/2 bg-white text-slate-800 text-xs font-semibold py-2 px-3.5 rounded-xl shadow-xl border border-slate-100 flex items-center gap-2.5 whitespace-nowrap transition-all duration-300 opacity-0 translate-x-4 pointer-events-none"
    >
      <span class="relative flex h-2 w-2">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-500"></span>
      </span>
      <span>Need tax help? Chat with us!</span>
      <button
        id="close-whatsapp-tooltip"
        class="ml-1 text-slate-400 hover:text-slate-600 focus:outline-none cursor-pointer transition-colors p-0.5 rounded-md hover:bg-slate-50"
        aria-label="Dismiss tooltip"
      >
        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    {/* Main Floating Button */}
    <a
      href={BUSINESS.whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="relative w-14 h-14 bg-gradient-to-br from-[#25D366] to-[#128C7E] text-white rounded-full flex items-center justify-center shadow-lg hover:shadow-xl hover:scale-105 active:scale-95 transition-all duration-300"
      aria-label="Chat on WhatsApp"
      id="whatsapp-btn"
    >
      {/* Pulse Effect Rings */}
      <span class="absolute inset-0 rounded-full bg-[#25D366] opacity-40 animate-ping-custom pointer-events-none"></span>
      <span class="absolute inset-0 rounded-full bg-[#25D366] opacity-20 animate-pulse-custom pointer-events-none"></span>
      
      {/* WhatsApp SVG Icon */}
      <svg class="w-7 h-7 transition-transform duration-300 group-hover:rotate-12" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
      </svg>
    </a>
  </div>
)}

<style>
  /* Custom pulse/ping animations for the outer rings */
  @keyframes ping-custom {
    0% {
      transform: scale(1);
      opacity: 0.5;
    }
    100% {
      transform: scale(1.6);
      opacity: 0;
    }
  }

  @keyframes pulse-custom {
    0%, 100% {
      transform: scale(1);
      opacity: 0.2;
    }
    50% {
      transform: scale(1.2);
      opacity: 0.4;
    }
  }

  .animate-ping-custom {
    animation: ping-custom 2s cubic-bezier(0, 0, 0.2, 1) infinite;
  }

  .animate-pulse-custom {
    animation: pulse-custom 3s ease-in-out infinite;
  }

  /* Tooltip hover effect */
  .whatsapp-group:hover #whatsapp-tooltip:not(.dismissed) {
    opacity: 1;
    transform: translateY(-50%) translateX(0);
    pointer-events: auto;
  }

  /* Automatic tooltip classes */
  #whatsapp-tooltip.show-tooltip {
    opacity: 1;
    transform: translateY(-50%) translateX(0);
    pointer-events: auto;
  }
  
  #whatsapp-tooltip.dismissed {
    opacity: 0 !important;
    transform: translateY(-50%) translateX(12px) !important;
    pointer-events: none !important;
  }
</style>

<script>
  function initWhatsAppTooltip() {
    const container = document.getElementById('whatsapp-container');
    const tooltip = document.getElementById('whatsapp-tooltip');
    const closeBtn = document.getElementById('close-whatsapp-tooltip');

    if (!container || !tooltip || !closeBtn) return;

    // Check if user has dismissed the tooltip previously
    const isDismissed = localStorage.getItem('whatsapp_tooltip_dismissed') === 'true';

    if (!isDismissed) {
      // Auto-show tooltip after 2.5 seconds
      const timeoutId = setTimeout(() => {
        tooltip.classList.add('show-tooltip');
      }, 2500);

      // Dismiss tooltip when clicking the 'x'
      closeBtn.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        clearTimeout(timeoutId);
        tooltip.classList.remove('show-tooltip');
        tooltip.classList.add('dismissed');
        localStorage.setItem('whatsapp_tooltip_dismissed', 'true');
      });
    }
  }

  // Support Astro view transitions or normal page loads
  document.addEventListener('astro:page-load', initWhatsAppTooltip);
  
  // Also run immediately on normal load
  initWhatsAppTooltip();
</script>
